{
  "cli": {
    "version": ">= 15.0.0",
    "appVersionSource": "local"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "environment": "development",
      "ios": {
        "simulator": true
      },
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://kai-platform-canvas.vercel.app"
      }
    },
    "preview": {
      "distribution": "internal",
      "channel": "preview",
      "environment": "preview",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://kai-platform-canvas.vercel.app",
        "EXPO_PUBLIC_PROJECT_ID": "7bced945-9c21-4745-b9c2-a214b8484ef6"
      }
    },
    "production": {
      "autoIncrement": true,
      "channel": "production",
      "environment": "production",
      "android": {
        "buildType": "app-bundle"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://kai-platform-canvas.vercel.app",
        "EXPO_PUBLIC_PROJECT_ID": "7bced945-9c21-4745-b9c2-a214b8484ef6"
      }
    },
    "production-apk": {
      "channel": "production",
      "environment": "production",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://kai-platform-canvas.vercel.app",
        "EXPO_PUBLIC_PROJECT_ID": "7bced945-9c21-4745-b9c2-a214b8484ef6"
      }
    }
  },
  "submit": {
    "production": {
      "android": {
        "serviceAccountKeyPath": "./google-play-service-account.json",
        "track": "production"
      }
    }
  }
}
